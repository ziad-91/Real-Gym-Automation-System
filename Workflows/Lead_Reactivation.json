    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n// If sheet is empty\nif (allItems.length === 0) {\n  return [\n    {\n      json: {\n        withinLastTwoWeeks: false,\n        latestRowFound: false\n      }\n    }\n  ];\n}\n\n// Sort by Trigger Date descending (newest first)\nallItems.sort((a, b) => {\n  return new Date(b.json[\"Trigger Date\"]) - new Date(a.json[\"Trigger Date\"]);\n});\n\n// Take only the latest row\nconst latestItem = allItems[0];\nconst triggerDateRaw = latestItem.json[\"Trigger Date\"];\n\nif (!triggerDateRaw) {\n  return [\n    {\n      json: {\n        ...latestItem.json,\n        withinLastTwoWeeks: false,\n        latestRowFound: true\n      }\n    }\n  ];\n}\n\nconst triggerDate = new Date(triggerDateRaw);\nconst twoWeeksAgo = new Date(Date.now() - 14 * 24 * 60 * 60 * 1000);\n\nreturn [\n  {\n    json: {\n      ...latestItem.json,\n      withinLastTwoWeeks: triggerDate >= twoWeeksAgo,\n      latestRowFound: true\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
