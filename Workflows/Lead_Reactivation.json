      "parameters": {
        "jsCode": "const raw = $json['Phone Number '];\n\nif (!raw || typeof raw !== 'string') {\n  return {\n    ...$json,\n    cleanedPhone: null,\n    phoneValid: false,\n  };\n}\n\nconst cleanedPhone = raw\n  .replace(/[\\u202A-\\u202E\\u2066-\\u2069]/g, '')\n  .replace(/[^\\d]/g, '')\n  .trim();\n\nreturn {\n  ...$json,\n  cleanedPhone,\n  phoneValid: cleanedPhone.length > 0,\n};\n"
